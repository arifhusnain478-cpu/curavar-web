{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web/ui && npm install && npm run build",
  "outputDirectory": "web/ui/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
