# ─── Secrets — NEVER commit real keys ────────────────────────────────────────
# The Anthropic API key lives in web/api/.env; keep it (and any other env file)
# out of the repo. Only the blank *.env.example templates are tracked.
.env
.env.*
**/.env
**/.env.*
web/api/.env
!.env.example
!**/.env.example
*.key
*.pem
secrets*.json

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Node / Vite / build output ──────────────────────────────────────────────
node_modules/
dist/
build/
web/ui/dist/
**/.vite/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Editors / OS ────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ─── Local build artifact (the shipped source zip) ───────────────────────────
curavar.zip
