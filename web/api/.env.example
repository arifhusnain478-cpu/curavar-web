# CuraVar API configuration.
#
# Copy this file to `.env` (in this same folder: web/api/.env) and paste your
# Anthropic API key after the `=` below. The key is loaded server-side on
# startup and never reaches the browser. Leave it blank to run in offline
# replay mode (the default; no key needed).
#
#   ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
ANTHROPIC_API_KEY=
